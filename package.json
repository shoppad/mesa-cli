{
  "name": "mesa-cli",
  "version": "3.0.0",
  "description": "Command-line interface to download, watch and publish Mesa Scripts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shoppad/mesa-cli.git"
  },
  "author": "ShopPad",
  "license": "AGPL-3.0",
  "bugs": {
    "url": "https://github.com/shoppad/mesa-cli/issues"
  },
  "homepage": "https://getmesa.com",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "cli": "node dist/cli.js",
    "dev": "npm run build && npm run cli",
    "test": "node --test dist/**/*.test.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "bin": {
    "mesa": "./dist/cli.js",
    "mesa-fields": "./dist/generate-fields.js"
  },
  "files": [
    "dist/**/*"
  ],
  "dependencies": {
    "@inquirer/prompts": "^8.2.0",
    "axios": "^1.7.0",
    "commander": "^12.1.0",
    "open": "^10.1.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
